# Site URL — used by @nuxtjs/seo for canonical/sitemap/og URLs
# Production: https://rentmi.uz
# Staging:    https://uzrentme.powerapp.uz
NUXT_PUBLIC_SITE_URL=http://localhost:4000

# Backend API base. In production the outer Nginx proxies /api/* to Django,
# so same-origin `/api/v1` works. For local dev against a remote backend,
# point this at the full origin, e.g. https://api-prod.powerapp.uz/api/v1
NUXT_PUBLIC_API_BASE=/api/v1
